package ffi_service

target(lang: ffi)

attrs (
    "rpl:ffi"
)

@ffi(server: "rust", clients: "go,go:purego,python,c,rust", library: "calculator", prefix: "calculator")
model CalculatorService {
    Name string

    func Add (left int64, right int64) return (int64)
    func Stats return (int64, float64)
}
