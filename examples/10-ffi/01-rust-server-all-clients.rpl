target(lang: ffi)

attrs (
    "rpl:ffi"
)

@ffi(
    server: "rust",
    clients: "go,go:purego,python,c,rust",
    library: "calculator",
    prefix: "calculator",
    abiVersion: 1,
)
model CalculatorService {
    ID int64
    Name string?
    Tags []string

    func Add (left int64, right int64) return (int64)
    func Stats return (int64, float64)
    func Describe (id int64) return (CalculatorService) @ffi(name: "describe")
    func InternalReset return (bool) @ffi(ignore: true)
}
